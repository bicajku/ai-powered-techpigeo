# Sentinel AI Suite - Environment Variables Template
# Never commit .env.local to version control
# ==========================================

# =============================================================================
# AUTHENTICATION & OAUTH
# =============================================================================
# JWT Secret for signing auth tokens (required)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/api/auth/github/callback

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Neon PostgreSQL Database URL
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
# Get this from: https://console.neon.tech
VITE_NEON_DATABASE_URL=

# =============================================================================
# AI MODEL PROVIDERS
# =============================================================================

# Google Gemini API Key
# Get this from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# GitHub Copilot Token (for advanced features)
# Get this from: GitHub Settings > Developer settings > Personal access tokens
VITE_GITHUB_COPILOT_TOKEN=

# =============================================================================
# SPARK RUNTIME CONFIGURATION
# =============================================================================

# Spark App ID (auto-generated, do not modify unless deploying to production)
VITE_SPARK_APP_ID=6ae71f4d37a1f80fc3a3

# Enable debug logging for Spark runtime
VITE_SPARK_DEBUG=false

# =============================================================================
# APPLICATION FEATURES
# =============================================================================

VITE_ENABLE_NGO_MODULE=true
# Enable plagiarism checker

VITE_ENABLE_HUMANIZER=true
# =========================

# Secret encryption salt (a


# ===================
# ========================


VITE_PRO_PLAN_BUDGET_CE
# Team plan monthly budget in cents (default: $50.00)

# DEVELOPMENT & DEBUGGING


# Enable performance monitoring


# =============================================================================
# ======================
# Default brand theme (novussparks_brand | novussparks_classic)

VITE_ALLOW_THEME_SWITCHING=true
# ==============================

# Sentry DSN for error tracking (optional)


# ===================================================
# ==============================

# 3. Use the secret-store module for runtime secret management
# 5. Missing required var

# =============================================================================
# PLATFORM MIGRATION (PHASE 2)
# =============================================================================

# Backend API for Spark-exit staged migration
VITE_BACKEND_API_BASE_URL=http://127.0.0.1:8787

# Keep all flags false by default for safe rollout
VITE_USE_BACKEND_LLM=false
VITE_USE_BACKEND_STORAGE=false
VITE_USE_BACKEND_AUTH=false
VITE_BACKEND_API_KEY=







































