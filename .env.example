# Sentinel AI Suite - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Neon PostgreSQL Database URL
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
# Get this from: https://console.neon.tech
VITE_NEON_DATABASE_URL=

# =============================================================================
# AI MODEL PROVIDERS
# =============================================================================

# Google Gemini API Key
# Get this from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# GitHub Copilot Token (for advanced features)
# Get this from: GitHub Settings > Developer settings > Personal access tokens
VITE_GITHUB_COPILOT_TOKEN=

# =============================================================================
# SPARK RUNTIME CONFIGURATION
# =============================================================================

# Spark App ID (auto-generated, do not modify unless deploying to production)
VITE_SPARK_APP_ID=6ae71f4d37a1f80fc3a3

# Enable debug logging for Spark runtime
VITE_SPARK_DEBUG=false

# =============================================================================
# APPLICATION FEATURES
# =============================================================================

# Enable Sentinel Brain module (admin only)
VITE_ENABLE_SENTINEL_BRAIN=true

# Enable NGO-SAAS module (enterprise only)
VITE_ENABLE_NGO_MODULE=true

# Enable plagiarism checker
VITE_ENABLE_PLAGIARISM_CHECKER=true

# Enable AI humanizer
VITE_ENABLE_HUMANIZER=true

# =============================================================================
# SECURITY & ENCRYPTION
# =============================================================================

# Secret encryption salt (auto-generated, do not modify)
VITE_SECRET_SALT=sentinel-secret-store-v1

# Session timeout in milliseconds (default: 24 hours)
VITE_SESSION_TIMEOUT=86400000

# =============================================================================
# RATE LIMITING & QUOTAS
# =============================================================================

# Basic plan monthly budget in cents (default: $5.00)
VITE_BASIC_PLAN_BUDGET_CENTS=500

# Pro plan monthly budget in cents (default: $20.00)
VITE_PRO_PLAN_BUDGET_CENTS=2000

# Team plan monthly budget in cents (default: $50.00)
VITE_TEAM_PLAN_BUDGET_CENTS=5000

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================

# Enable verbose error logging
VITE_VERBOSE_ERRORS=false

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# Mock AI responses for development (no API calls)
VITE_MOCK_AI_RESPONSES=false

# =============================================================================
# BRANDING & THEMING
# =============================================================================

# Default brand theme (sentinel_modern | techpigeon_classic)
VITE_DEFAULT_BRAND_THEME=sentinel_modern

# Allow theme switching in UI
VITE_ALLOW_THEME_SWITCHING=true

# =============================================================================
# EXTERNAL INTEGRATIONS (Optional)
# =============================================================================

# Sentry DSN for error tracking (optional)
VITE_SENTRY_DSN=

# Analytics tracking ID (optional)
VITE_ANALYTICS_ID=

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. All variables prefixed with VITE_ are exposed to the client-side bundle
# 2. Never include sensitive keys in version control
# 3. Use the secret-store module for runtime secret management
# 4. Environment variables are validated on app startup
# 5. Missing required variables will trigger warnings in development mode
#
