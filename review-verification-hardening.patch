+
+function clampScore(value: unknown, fallback = 0): number {
+  const numeric = typeof value === "number" ? value : Number(value)
+
+  if (!Number.isFinite(numeric)) {
+    return fallback
+  }
+
+  return Math.min(100, Math.max(0, Math.round(numeric)))
+}
