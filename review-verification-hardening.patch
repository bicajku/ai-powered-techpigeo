+    status,
+    canPerformLiveCheck: activeChecks.some((check) => check.canPerformLiveCheck),
+    canVerifyRetention: activeChecks.some((check) => check.canVerifyRetention),
+    checkedAt: Date.now(),
+    summary: buildSummary(activeChecks, matches.length),
